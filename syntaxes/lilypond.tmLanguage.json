{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "LilyPond",
  "scopeName": "source.lilypond",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#lyrics" },
    { "include": "#markup" },
    { "include": "#music" },
    { "include": "#scheme" },
    { "include": "#commands" },
    { "include": "#operators" },
    { "include": "#declarations" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.lilypond",
          "begin": "%\\{",
          "end": "%\\}"
        },
        {
          "name": "comment.line.percentage.lilypond",
          "match": "%.*$"
        }
      ]
    },
    "durations": {
      "patterns": [
        {
          "name": "constant.numeric.duration.lilypond",
          "match": "(1|2|4|8|16|32|64|128|256|512|1024|\\\\breve|\\\\longa)\\.?(\\*\\d+)?\\b"
        }
      ]
    },
    "lyrics": {
      "patterns": [
        {
          "begin": "(\\\\lyricmode)\\s*(\\{)",
          "end": "\\}",
          "beginCaptures": {
            "1": { "name": "support.function.lilypond" },
            "2": { "name": "punctuation.section.braces.lilypond" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.braces.lilypond" }
          },
          "contentName": "string.quoted.other.lyrics.lilypond",
          "patterns": [
            { "include": "#comments" },
            { "include": "#markup" },
            { "include": "#commands" },
            { "include": "#durations" },
            { "name": "constant.character.lilypond", "match": "--" }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.lilypond",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.lilypond",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "commands": {
      "patterns": [
        {
          "name": "support.function.lilypond",
          "match": "\\\\[a-zA-Z]+\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "variable.other.declaration.lilypond",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_'`-]*)\\s*=\\s*"
        }
      ]
    },
    "music": {
      "patterns": [
        {
          "name": "constant.language.note.lilypond",
          "match": "\\b[a-gr]([ie]?s{1,2}|[ie]?ss)?[',]*\\d*\\.*(\\*\\d+(/\\d+)?)?(!|\\?|\\+|-|_|\\^)?\\b"
        },
        {
          "name": "constant.language.rest.lilypond",
          "match": "\\b(r|R|s)\\d*\\.*(\\*\\d+(/\\d+)?)?\\b"
        },
        {
          "name": "meta.parallel.lilypond",
          "begin": "<<",
          "end": ">>",
          "patterns": [
            { "include": "#music" },
            { "include": "#comments" }
          ]
        },
        {
          "name": "meta.chord.lilypond",
          "begin": "(?<!\\\\)<",
          "end": ">",
          "patterns": [
            { "include": "#music" }
          ]
        },
        { "include": "#durations" },
        { "include": "#commands" },
        { "include": "#comments" }
      ]
    },
    "markup": {
      "patterns": [
        {
          "name": "meta.markup.lilypond",
          "begin": "(\\\\markup)\\s*(\\{)",
          "end": "\\}",
          "beginCaptures": {
            "1": { "name": "support.function.lilypond" },
            "2": { "name": "punctuation.section.braces.lilypond" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.braces.lilypond" }
          },
          "contentName": "string.quoted.other",
          "patterns": [
            { "include": "#markup-commands" },
            { "include": "#strings" },
            { "include": "#comments" },
            {
              "name": "punctuation.section.braces.lilypond",
              "match": "[{}]"
            },
            { "include": "#commands" }
          ]
        }
      ]
    },
    "markup-commands": {
      "patterns": [
        {
          "begin": "(\\\\italic)\\s*(\\{)",
          "end": "\\}",
          "beginCaptures": {
            "1": { "name": "support.function.lilypond" },
            "2": { "name": "punctuation.section.braces.lilypond" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.braces.lilypond" }
          },
          "contentName": "markup.italic",
          "patterns": [
            { "include": "#markup-commands" },
            { "include": "#strings" },
            { "include": "#comments" }
          ]
        },
        {
          "begin": "(\\\\bold)\\s*(\\{)",
          "end": "\\}",
          "beginCaptures": {
            "1": { "name": "support.function.lilypond" },
            "2": { "name": "punctuation.section.braces.lilypond" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.braces.lilypond" }
          },
          "contentName": "markup.bold",
          "patterns": [
            { "include": "#markup-commands" },
            { "include": "#strings" },
            { "include": "#comments" }
          ]
        },
        {
          "begin": "(\\\\underline)\\s*(\\{)",
          "end": "\\}",
          "beginCaptures": {
            "1": { "name": "support.function.lilypond" },
            "2": { "name": "punctuation.section.braces.lilypond" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.braces.lilypond" }
          },
          "contentName": "markup.underline",
          "patterns": [
            { "include": "#markup-commands" },
            { "include": "#strings" },
            { "include": "#comments" }
          ]
        },
        {
          "match": "(\\\\italic)\\s+(\\S+)",
          "captures": {
            "1": { "name": "support.function.lilypond" },
            "2": { "name": "markup.italic" }
          }
        },
        {
          "match": "(\\\\bold)\\s+(\\S+)",
          "captures": {
            "1": { "name": "support.function.lilypond" },
            "2": { "name": "markup.bold" }
          }
        },
        {
          "match": "(\\\\underline)\\s+(\\S+)",
          "captures": {
            "1": { "name": "support.function.lilypond" },
            "2": { "name": "markup.underline" }
          }
        }
      ]
    },
    "scheme": {
      "patterns": [
        {
          "contentName": "meta.embedded.block.scheme.lilypond",
          "begin": "#\\(",
          "end": "\\)",
          "beginCaptures": {
            "0": { "name": "punctuation.section.embedded.begin.scheme.lilypond" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.embedded.end.scheme.lilypond" }
          },
          "patterns": [
            { "include": "source.scheme" }
          ]
        },
        {
          "name": "meta.embedded.expression.scheme.lilypond",
          "contentName": "source.scheme.embedded.lilypond.expression",
          "begin": "#(?=[a-zA-Z'`_-])",
          "end": "(?![a-zA-Z0-9_>?!-])",
          "patterns": [
            { "include": "source.scheme" }
          ]
        }
      ]
    },
    "scheme-lilypond-block": {
      "patterns": [
        {
          "contentName": "meta.embedded.block.lilypond.scheme",
          "begin": "#\\{",
          "end": "#\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.section.embedded.begin.lilypond.scheme" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.embedded.end.lilypond.scheme" }
          },
          "patterns": [
            { "include": "#comments" },
            { "include": "#strings" },
            { "include": "#commands" },
            { "include": "#music" },
            { "include": "#markup" },
            { "include": "#scheme" },
            { "include": "#operators" }
          ]
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.lilypond",
          "match": "[=~|]"
        },
        {
          "name": "punctuation.section.braces.lilypond",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.brackets.lilypond",
          "match": "[\\[\\]]"
        }
      ]
    }
  }
}
