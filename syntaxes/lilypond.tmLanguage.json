{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "LilyPond",
  "scopeName": "source.lilypond",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#commands" },
    { "include": "#notes" },
    { "include": "#chords" },
    { "include": "#markup" },
    { "include": "#scheme" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.lilypond",
          "begin": "%\\{",
          "end": "%\\}",
          "patterns": [
            { "include": "#comments" }
          ]
        },
        {
          "name": "comment.line.percentage.lilypond",
          "match": "%.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.lilypond",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.lilypond",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.lilypond",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.lilypond",
          "match": "\\\\(include|version|sourcefilename|sourcefileline)\\b"
        },
        {
          "name": "keyword.other.lilypond",
          "match": "\\\\(new|context|with|consists|remove|accepts|alias|defaultchild|denies|name|type|description)\\b"
        },
        {
          "name": "storage.type.lilypond",
          "match": "\\\\(paper|layout|midi|header|score|book|bookpart)\\b"
        }
      ]
    },
    "commands": {
      "patterns": [
        {
          "name": "support.function.lilypond",
          "match": "\\\\[a-zA-Z]+\\b"
        }
      ]
    },
    "notes": {
      "patterns": [
        {
          "name": "entity.name.tag.note.lilypond",
          "match": "\\b[a-gr]([ie]?s{1,2}|[ie]?ss)?[',]*\\d*\\.*(\\*\\d+(/\\d+)?)?(!|\\?|\\+|-|_|\\^)?\\b"
        },
        {
          "name": "keyword.other.rest.lilypond",
          "match": "\\b(r|R|s)\\d*\\.*(\\*\\d+(/\\d+)?)?\\b"
        }
      ]
    },
    "chords": {
      "patterns": [
        {
          "name": "entity.name.tag.chord.lilypond",
          "begin": "<",
          "end": ">",
          "patterns": [
            { "include": "#notes" },
            { "include": "#comments" }
          ]
        }
      ]
    },
    "markup": {
      "patterns": [
        {
          "name": "meta.markup.lilypond",
          "begin": "\\\\markup\\b",
          "end": "(?=\\}|\\\\[a-zA-Z]+|>>)",
          "patterns": [
            { "include": "#strings" },
            { "include": "#comments" },
            { "include": "#commands" },
            {
              "name": "punctuation.section.braces.lilypond",
              "match": "[{}]"
            }
          ]
        }
      ]
    },
    "scheme": {
      "patterns": [
        {
          "contentName": "meta.embedded.block.scheme.lilypond",
          "begin": "#\\(",
          "end": "\\)",
          "beginCaptures": {
            "0": { "name": "punctuation.section.embedded.begin.scheme.lilypond" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.embedded.end.scheme.lilypond" }
          },
          "patterns": [
            { "include": "source.scheme" }
          ]
        },
        {
          "name": "meta.embedded.expression.scheme.lilypond",
          "contentName": "source.scheme.embedded.lilypond.expression",
          "begin": "#(?=[a-zA-Z'`_-])",
          "end": "(?![a-zA-Z0-9_>?!-])",
          "patterns": [
            { "include": "source.scheme" }
          ]
        }
      ]
    },
    "scheme-lilypond-block": {
      "patterns": [
        {
          "contentName": "meta.embedded.block.lilypond.scheme",
          "begin": "#\\{",
          "end": "#\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.section.embedded.begin.lilypond.scheme" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.embedded.end.lilypond.scheme" }
          },
          "patterns": [
            { "include": "#comments" },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#keywords" },
            { "include": "#commands" },
            { "include": "#notes" },
            { "include": "#chords" },
            { "include": "#markup" },
            { "include": "#scheme" },
            { "include": "#operators" }
          ]
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.lilypond",
          "match": "[=~|]"
        },
        {
          "name": "punctuation.section.braces.lilypond",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.brackets.lilypond",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.separator.lilypond",
          "match": "[,;]"
        }
      ]
    }
  }
}
